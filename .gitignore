__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
build/
dist/

# Local Claude Code settings / session runtime state
.claude/

# Environments
.venv/
venv/

# OS / editors
.DS_Store
.idea/
.vscode/
